---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: 'Elite Metalwork',
    description: 'Επαγγελματική παρουσίαση μεταλλικών κατασκευών με έμφαση στην λεπτομέρεια.',
    image: '/images/elite-metalwork.jpg',
    alt: 'Elite Metalwork Professional Welding',
  },
  {
    title: 'Nutritionist Site',
    description: 'Μοντέρνα πλατφόρμα για διατροφολόγο με σύστημα ραντεβού και blog.',
    image: '/images/nutritionist.png',
  },
  {
    title: 'Web Titans Stage',
    description: 'High-performance landing page για digital agency.',
    image: '/images/webtitans.png',
  },
  {
    title: 'Intzikiotis',
    description: 'Πλήρως παραμετροποιημένο e-shop με custom WordPress theme.',
    image: '/images/intzikiotis.png',
    tag: 'WordPress',
  },
];
---

<section id="projects" class="py-24 bg-black/20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Επιλεγμένα Έργα</h2>
      <div class="mt-2 h-1.5 w-20 bg-indigo-600 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-2">
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </div>
</section>
