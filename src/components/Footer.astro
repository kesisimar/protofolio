---
---

<section class="w-full bg-[#0a0a0a] border-t border-white/5 pt-32 pb-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Methodology Content -->
      <div>
        <span class="text-indigo-500 text-xs font-bold tracking-widest uppercase mb-4 block">ΜΕΘΟΔΟΛΟΓΙΑ</span>
        <h2 class="text-4xl font-bold text-white mb-6 leading-tight">
          Καθαρός Κώδικας,<br />Αθόρυβη Εκτέλεση.
        </h2>
        <p class="text-zinc-400 text-sm leading-relaxed mb-10 max-w-md">
          Πιστεύω στη μείωση του τεχνικού χρέους και στα υπερ-βελτιστοποιημένα assets. 
          Κάθε γραμμή κώδικα γράφεται με γνώμονα την απόδοση και τη μακροζωία.
        </p>

        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-sm text-zinc-300">
            <div class="h-5 w-5 rounded-full border border-indigo-500/30 flex items-center justify-center bg-indigo-500/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            Type-safe αρχιτεκτονικά πρότυπα
          </li>
          <li class="flex items-center gap-3 text-sm text-zinc-300">
            <div class="h-5 w-5 rounded-full border border-indigo-500/30 flex items-center justify-center bg-indigo-500/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            Serverless λογική με ελάχιστη καθυστέρηση
          </li>
          <li class="flex items-center gap-3 text-sm text-zinc-300">
            <div class="h-5 w-5 rounded-full border border-indigo-500/30 flex items-center justify-center bg-indigo-500/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            Σχεδιασμός components με βάση την προσβασιμότητα
          </li>
        </ul>
      </div>

      <!-- Code Window -->
      <div class="relative">
        <div class="absolute -inset-2 rounded-2xl bg-indigo-500/5 blur-2xl"></div>
        <div class="relative rounded-xl bg-[#0d0d0d] border border-white/10 overflow-hidden shadow-2xl">
          <div class="bg-zinc-900/50 px-4 py-3 border-b border-white/5 flex items-center justify-between">
            <div class="flex gap-1.5">
              <div class="h-3 w-3 rounded-full bg-[#ff5f56]"></div>
              <div class="h-3 w-3 rounded-full bg-[#ffbd2e]"></div>
              <div class="h-3 w-3 rounded-full bg-[#27c93f]"></div>
            </div>
            <span class="text-[10px] text-zinc-500 font-mono">architect.ts</span>
          </div>
          <div class="p-6 font-mono text-[13px] leading-relaxed">
            <p class="text-indigo-400">interface <span class="text-zinc-100">Project</span> {"{"}</p>
            <p class="pl-4 text-zinc-400">id: <span class="text-yellow-400">string</span>;</p>
            <p class="pl-4 text-zinc-400">status: <span class="text-green-400">'optimized'</span> | <span class="text-green-400">'deploying'</span>;</p>
            <p class="pl-4 text-zinc-400">performance_score: <span class="text-yellow-400">number</span>;</p>
            <p class="text-indigo-400">{"}"}</p>
            <br />
            <p class="text-indigo-400">const <span class="text-zinc-100">initializeDeployment</span> = (config: Config) => {"{"}</p>
            <p class="pl-4 text-zinc-500">// Εκτέλεση αθόρυβης αρχιτεκτονικής...</p>
            <p class="pl-4 text-indigo-400">return <span class="text-zinc-300">config.optimize().deploy();</span></p>
            <p class="text-indigo-400">{"}"}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="w-full bg-[#050505] pt-32 pb-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-20">
      <h3 class="text-xl font-bold text-white mb-10">Architect</h3>
      
      <div class="flex justify-center gap-12 mb-20 text-xs font-bold text-zinc-500 tracking-widest uppercase">
        <a href="#" class="hover:text-white transition-colors">Πηγαίος Κώδικας</a>
        <a href="#" class="hover:text-white transition-colors">LinkedIn</a>
        <a href="#" class="hover:text-white transition-colors">Τερματικό</a>
      </div>

      <h2 class="text-5xl sm:text-7xl lg:text-8xl font-black text-white tracking-tighter mb-20">
        Επικοινωνήστε
      </h2>

      <p class="text-[10px] text-zinc-600 uppercase tracking-[0.2em] mb-12">
        © 2026 Silent Architect. Σχεδιασμένο για απόδοση.
      </p>

      <div class="flex justify-center gap-4">
        <div class="h-10 w-10 rounded-full border border-white/10 flex items-center justify-center text-zinc-400 hover:text-white hover:border-white transition-all cursor-pointer bg-zinc-900/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        </div>
        <div class="h-10 w-10 rounded-full border border-white/10 flex items-center justify-center text-zinc-400 hover:text-white hover:border-white transition-all cursor-pointer bg-zinc-900/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>
        </div>
        <div class="h-10 w-10 rounded-full border border-white/10 flex items-center justify-center text-zinc-400 hover:text-white hover:border-white transition-all cursor-pointer bg-zinc-900/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </div>
      </div>
    </div>
  </div>
</footer>
